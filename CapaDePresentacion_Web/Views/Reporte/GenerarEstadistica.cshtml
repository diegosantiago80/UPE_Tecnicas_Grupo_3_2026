@using System
@using System.Collections.Generic
@using System.Linq
@using CapaDeEntidades;

@model IEnumerable<Reporte>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Estadísticas de Medicamentos";

    // Calculamos los totales usando un bucle estándar para evitar errores de dispatch dinámico en Razor
    int totalUnidadesVendidas = 0;
    int totalStockDisponible = 0;
    bool hayDatos = false;

    if (Model != null)
    {
        foreach (var item in Model)
        {
            totalUnidadesVendidas += item.UnidadesVendidas;
            totalStockDisponible += item.StockDisponible;
            hayDatos = true;
        }
    }
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <div>
                <h1 class="h4 mb-1 text-primary">Estadísticas de Medicamentos</h1>
                <p class="text-muted small mb-0">Control de unidades vendidas, comparación mensual y disponibilidad en stock</p>
            </div>

            <form method="get" class="d-flex gap-2 mb-0">
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" name="buscarMedicamento" class="form-control border-start-0 w-auto" id="buscarMedicamento" placeholder="Nombre de medicamento..." title="Buscar por medicamento" />
                </div>
                <button type="submit" class="btn btn-primary px-4">Buscar</button>
            </form>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Medicamento</th>
                            <th class="text-center">Unidades Vendidas</th>
                            <th class="text-center">Comparación Mes Anterior</th>
                            <th class="text-center">Stock Disponible</th>
                            <th class="text-center pe-4">Prioridad de compra</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (hayDatos)
                        {
                            foreach (var item in Model)
                            {
                                // 1. Preparamos los estilos del badge de comparación de ventas
                                string compClass = "badge bg-light text-muted border px-2 py-1.5 fw-bold";
                                string compIcon = "bi bi-dash";
                                string compSign = "";
                                if (item.PorcentajeVariacion > 0)
                                {
                                    compClass = "badge bg-success-subtle text-success border border-success-subtle px-2 py-1.5 fw-bold";
                                    compIcon = "bi bi-arrow-up-short";
                                    compSign = "+";
                                }
                                else if (item.PorcentajeVariacion < 0)
                                {
                                    compClass = "badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1.5 fw-bold";
                                    compIcon = "bi bi-arrow-down-short";
                                }

                                // 2. Preparamos los estilos del stock
                                string stockClass = "badge bg-success px-3 py-2";
                                string stockLabel = "";
                                if (item.StockDisponible <= 10)
                                {
                                    stockClass = "badge bg-danger px-3 py-2";
                                    stockLabel = " - Crítico";
                                }
                                else if (item.StockDisponible <= 30)
                                {
                                    stockClass = "badge bg-warning text-dark px-3 py-2";
                                    stockLabel = " - Bajo";
                                }

                                // 3. CÁLCULO DE PRIORIDAD DE COMPRA (DIAS DE STOCK RESTANTE)
                                int diaActual = DateTime.Today.Day;
                                double ventasDiarias = (double)item.UnidadesVendidas / (diaActual > 0 ? diaActual : 1);

                                double diasDeStockRestante = 999.0;
                                if (ventasDiarias > 0)
                                {
                                    diasDeStockRestante = (double)item.StockDisponible / ventasDiarias;
                                }

                                string prioridadCompra = "No necesario";
                                string prioridadClass = "badge bg-success-subtle text-success border border-success-subtle px-3 py-2 fw-bold";

                                if (diasDeStockRestante <= 7)
                                {
                                    prioridadCompra = "Compra Urgente";
                                    prioridadClass = "badge bg-danger px-3 py-2 fw-bold";
                                }
                                else if (diasDeStockRestante <= 20)
                                {
                                    prioridadCompra = "Soporta Stock";
                                    prioridadClass = "badge bg-warning text-dark px-3 py-2 fw-bold";
                                }

                                <tr>
                                    <td class="fw-semibold ps-4 text-dark">@item.Medicamento</td>

                                    <td class="text-center fw-bold text-secondary">
                                        @item.UnidadesVendidas.ToString("N0")
                                    </td>

                                    <td class="text-center">
                                        <span class="@compClass">
                                            <i class="@compIcon"></i>@compSign@item.PorcentajeVariacion.ToString("0.0")%
                                        </span>
                                    </td>

                                    <td class="text-center">
                                        <span class="@stockClass" title="Stock disponible">
                                            @item.StockDisponible<span class="d-none d-sm-inline">@stockLabel</span>
                                        </span>
                                    </td>

                                    <td class="text-center pe-4">
                                        <span class="@prioridadClass" title="Días estimados de stock: @(diasDeStockRestante > 365 ? "Abundante" : diasDeStockRestante.ToString("0.0"))">
                                            @prioridadCompra
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5 fs-6">
                                    <div class="mb-2">
                                        <i class="bi bi-journal-x fs-2 text-secondary"></i>
                                    </div>
                                    No se encontraron estadísticas para el medicamento ingresado.
                                </td>
                            </tr>
                        }
                    </tbody>

                    @if (hayDatos)
                    {
                        <tfoot class="table-light border-top-2">
                            <tr>
                                <td class="fw-bold py-3 ps-4 text-end text-secondary">Total General:</td>
                                <td class="text-center fw-bold fs-5 py-3 text-primary">
                                    @totalUnidadesVendidas.ToString("N0")
                                </td>
                                <td></td>
                                <td class="text-center fw-bold fs-5 py-3 text-primary">
                                    @totalStockDisponible.ToString("N0")
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const urlParams = new URLSearchParams(window.location.search);

            const buscarMedicamento = urlParams.get('buscarMedicamento');
            if (buscarMedicamento) {
                document.getElementById('buscarMedicamento').value = buscarMedicamento;
            }
        });
    </script>
}