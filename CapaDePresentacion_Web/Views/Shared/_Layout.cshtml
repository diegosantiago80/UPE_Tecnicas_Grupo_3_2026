@using Microsoft.AspNetCore.Http
@using CapaDeLogicaDeNegocio_BLL
@inject IHttpContextAccessor HttpContextAccessor
@{
    
    var idPerfil = HttpContextAccessor.HttpContext.Session.GetInt32("IdPerfil");
    var nombreUsuario = HttpContextAccessor.HttpContext.Session.GetString("NombreUsuario");
    var nombreRol = HttpContextAccessor.HttpContext.Session.GetString("NombreRol");

    // cada item del menu se decide preguntandole al composite si el perfil tiene el permiso
    var auth = AuthService.Instance;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Farmacia UPE</title>
    <link rel="icon" type="image/x-icon" href="@Url.Content("~/favicon.ico?")" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CapaDePresentacion_Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm mb-3">
            <div class="container-fluid px-3">

                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-capsule-pill fs-5"></i> Farmacia UPE
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1"></i>Inicio
                            </a>
                        </li>

                        @if (auth.PerfilTienePermiso(idPerfil, "RegistrarVenta"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Venta" asp-action="Registrar">
                                    <i class="bi bi-cart-check me-1"></i>Ventas
                                </a>
                            </li>
                        }

                        @if (auth.PerfilTienePermiso(idPerfil, "GestionarClientes"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Cliente" asp-action="Gestionar">
                                    <i class="bi bi-people me-1"></i>Clientes
                                </a>
                            </li>
                        }

                        @if (auth.PerfilTienePermiso(idPerfil, "ControlStock") || auth.PerfilTienePermiso(idPerfil, "RegistrarCompra") || auth.PerfilTienePermiso(idPerfil, "GestionarMedicamentos") || auth.PerfilTienePermiso(idPerfil, "GestionarLaboratorios"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-box-seam me-1"></i>Inventario
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    @if (auth.PerfilTienePermiso(idPerfil, "ControlStock"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Medicamento" asp-action="Index">
                                                <i class="bi bi-bar-chart-line me-2"></i>Control de Stock
                                            </a>
                                        </li>
                                    }
                                    @if (auth.PerfilTienePermiso(idPerfil, "RegistrarCompra"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Compra" asp-action="Registrar">
                                                <i class="bi bi-truck me-2"></i>Registrar Compra
                                            </a>
                                        </li>
                                    }
                                    @if (auth.PerfilTienePermiso(idPerfil, "GestionarMedicamentos"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Medicamento" asp-action="Gestionar">
                                                <i class="bi bi-capsule me-2"></i>Medicamentos
                                            </a>
                                        </li>
                                    }
                                    @if (auth.PerfilTienePermiso(idPerfil, "GestionarLaboratorios"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Laboratorio" asp-action="Index">
                                                <i class="bi bi-building me-2"></i>Laboratorios
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }

                        @if (auth.PerfilTienePermiso(idPerfil, "VerReporte") || auth.PerfilTienePermiso(idPerfil, "GenerarEstadisticas") || auth.PerfilTienePermiso(idPerfil, "GenerarProyeccion"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-graph-up-arrow me-1"></i>Reportes
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    @if (auth.PerfilTienePermiso(idPerfil, "VerReporte"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Reporte" asp-action="VerReporte">
                                                <i class="bi bi-receipt me-2"></i>Reporte de Ventas
                                            </a>
                                        </li>
                                    }
                                    @if (auth.PerfilTienePermiso(idPerfil, "GenerarEstadisticas"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Reporte" asp-action="GenerarEstadistica">
                                                <i class="bi bi-bar-chart me-2"></i>Estadísticas
                                            </a>
                                        </li>
                                    }
                                    @if (auth.PerfilTienePermiso(idPerfil, "GenerarProyeccion"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Reporte" asp-action="Proyeccion">
                                                <i class="bi bi-graph-up me-2"></i>Proyecciones
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }

                        @if (auth.PerfilTienePermiso(idPerfil, "GestionarUsuarios") || auth.PerfilTienePermiso(idPerfil, "ConfigurarPerfiles"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock me-1"></i>Administración
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    @if (auth.PerfilTienePermiso(idPerfil, "GestionarUsuarios"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Usuarios" asp-action="Index">
                                                <i class="bi bi-person-gear me-2"></i>Usuarios
                                            </a>
                                        </li>
                                    }
                                    @if (auth.PerfilTienePermiso(idPerfil, "ConfigurarPerfiles"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Perfiles" asp-action="Index">
                                                <i class="bi bi-person-badge me-2"></i>Perfiles
                                            </a>
                                        </li>
                                    }
                                    @if (auth.PerfilTienePermiso(idPerfil, "ConsultarLog"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Auditoria" asp-action="Index">
                                                <i class="bi bi-journal-text me-2"></i>Consultar Auditoría
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </li>
                        }

                    </ul>

                    @if (idPerfil != null)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-person-circle text-secondary fs-5"></i>
                            <span class="text-white-50 small">@nombreUsuario</span>
                            <span class="badge bg-primary">@nombreRol</span>
                            <a class="btn btn-sm btn-outline-light ms-2" asp-controller="Account" asp-action="Logout">
                                <i class="bi bi-box-arrow-right me-1"></i>Salir
                            </a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 Developed by G3 Media Studio
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
