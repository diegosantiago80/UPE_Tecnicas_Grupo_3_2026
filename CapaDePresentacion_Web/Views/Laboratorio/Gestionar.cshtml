@model CapaDeEntidades.Laboratorio

@{
    bool esNuevo = Model.IdLaboratorio == 0;
    ViewData["Title"] = esNuevo ? "Nuevo Laboratorio" : "Editar Laboratorio";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Guardar" method="post">
                <input type="hidden" name="IdLaboratorio" value="@Model.IdLaboratorio" />

                <div class="mb-3">
                    <label class="form-label">Razón Social <span class="text-danger">*</span></label>
                    <input type="text" name="RazonSocial" value="@Model.RazonSocial"
                           class="form-control" required maxlength="200" />
                </div>

                <div class="mb-3">
                    <label class="form-label">CUIT <span class="text-danger">*</span></label>
                    <input type="text" name="Cuit" value="@Model.Cuit"
                           class="form-control" required maxlength="15" placeholder="30-12345678-9" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Teléfono</label>
                        <input type="text" name="Telefono" value="@Model.Telefono"
                               class="form-control" maxlength="20" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="Email" value="@Model.Email"
                               class="form-control" maxlength="100" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Dirección</label>
                    <input type="text" name="Direccion" value="@Model.Direccion"
                           class="form-control" maxlength="200" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        @(esNuevo ? "Agregar Laboratorio" : "Guardar Cambios")
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
