@model IEnumerable<CapaDeEntidades.Usuario>
@using CapaDeLogicaDeNegocio_BLL
@{
    ViewData["Title"] = "Gestionar Usuarios";
}

<div class="container mt-4">
    <div class="card shadow-sm border-1" style="border-radius: 15px;">

        <div class="card-header bg-warning text-dark" style="padding: 12px 20px; border-top-left-radius: 15px; border-top-right-radius: 15px;">
            <h5 class="mb-0 fw-bold">Gestión de Usuarios</h5>
        </div>

        <div class="card-body p-4">
            @if (TempData["Exito"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2" style="border-radius: 10px;">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@TempData["Exito"]</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@TempData["Error"]</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="d-flex justify-content-end mb-3">
                <a href="/Usuarios/Crear" class="btn bg-warning text-dark px-4 shadow-sm" title="Registrar Usuario" style="font-weight: 500; border-radius: 20px;">
                    + Nuevo Usuario
                </a>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle" style="border-collapse: separate; border-spacing: 0;">
                    <thead class="table-light text-center">
                        <tr>
                            <th>Usuario</th>
                            <th>Perfil</th>
                            <th>DNI</th>
                            <th>Nombre Completo</th>
                            <th style="width: 120px;">Modificar</th>
                            <th style="width: 120px;">Eliminar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var user in Model)
                            {
                                var nombrePerfil = AuthService.Instance.ObtenerPerfilPorId(user.IdPerfil)?.Nombre ?? "Sin Rol";
                                <tr>
                                    <td class="text-center">@user.NombreUsuario</td>
                                    <td class="fw-bold text-muted text-center">@nombrePerfil</td>
                                    <td class="text-center">@user.Dni</td>
                                    <td class="text-center">@user.NombreCompleto</td>
                                    <td class="text-center">
                                        <a href="/Usuarios/Editar/@user.IdUsuario" class="btn btn-sm btn-outline-secondary" style="border-radius: 10px;" title="Modificar Datos">
                                            ✏️ Editar
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <button type="button" class="btn btn-sm btn-outline-danger"
                                                onclick="prepararBaja('@user.IdUsuario', '@user.NombreCompleto')">
                                            Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelector('[name="Dni"]').addEventListener('input', function () {
            this.value = this.value.replace(/[^0-9]/g, '');
        });

        document.querySelector('[name="Telefono"]').addEventListener('input', function () {
            this.value = this.value.replace(/[^0-9]/g, '');
        });

        document.querySelector('[name="NombreUsuario"]').addEventListener('input', function () { 
            this.value = this.value.replace(/[^A-Za-z0-9]/g, '');
        });

        document.querySelector('[name="Contrasena"]').addEventListener('input', function () {
            this.value = this.value.replace(/[^A-Za-z0-9]/g, '');
        });

        document.querySelector('[name="Nombre"]').addEventListener('input', function () {
            this.value = this.value.replace(/[^A-Za-zÀ-ÿÑñ ]/g, '').replace(/ {2,}/g, ' ').replace(/^ /, '');
        });

        document.querySelector('[name="Apellido"]').addEventListener('input', function () {
            this.value = this.value.replace(/[^A-Za-zÀ-ÿÑñ ]/g, '').replace(/ {2,}/g, ' ').replace(/^ /, '');
        });

        function prepararBaja(id, nombre) {
            Swal.fire({
                icon: "warning",
                title: "¿Eliminar usuario?",
                html: `Esta acción dará de baja a <strong>${nombre}</strong>.`,
                showCancelButton: true,
                confirmButtonText: "Sí, eliminar",
                cancelButtonText: "Cancelar",
                confirmButtonColor: "#dc3545",
                cancelButtonColor: "#6c757d"
            }).then(result => {
                if (result.isConfirmed){
                    window.location.href = '/Usuarios/Eliminar/' + id;
                }
            });
        }
    </script>
}
