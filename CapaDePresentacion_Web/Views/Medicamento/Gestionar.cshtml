@model CapaDeEntidades.Medicamento

@{
    bool esNuevo = Model.IdMedicamento == 0;
    ViewData["Title"] = esNuevo ? "Nuevo Medicamento" : "Editar Medicamento";
    var laboratorios = ViewBag.Laboratorios as IEnumerable<CapaDeEntidades.Laboratorio> ?? new List<CapaDeEntidades.Laboratorio>();
    var categorias   = ViewBag.Categorias   as IEnumerable<CapaDeEntidades.Categoria>   ?? new List<CapaDeEntidades.Categoria>();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Guardar" method="post">
                <input type="hidden" name="IdMedicamento" value="@Model.IdMedicamento" />

                <div class="mb-3">
                    <label class="form-label">Nombre <span class="text-danger">*</span></label>
                    <input type="text" name="Nombre" value="@Model.Nombre"
                           class="form-control" required maxlength="150" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Descripción</label>
                    <input type="text" name="Descripcion" value="@Model.Descripcion"
                           class="form-control" maxlength="300" />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Laboratorio <span class="text-danger">*</span></label>
                        <select name="IdLaboratorio" class="form-select" required>
                            <option value="">-- Seleccionar --</option>
                            @foreach (var lab in laboratorios)
                            {
                                <option value="@lab.IdLaboratorio" selected="@(lab.IdLaboratorio == Model.IdLaboratorio)">@lab.RazonSocial</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Categoría <span class="text-danger">*</span></label>
                        <select name="IdCategoria" class="form-select" required>
                            <option value="">-- Seleccionar --</option>
                            @foreach (var cat in categorias)
                            {
                                <option value="@cat.IdCategoria" selected="@(cat.IdCategoria == Model.IdCategoria)">@cat.Nombre</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Precio Venta <span class="text-danger">*</span></label>
                        <input type="number" name="PrecioVenta" value="@Model.PrecioVenta"
                               class="form-control" required min="0.01" step="0.01" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">
                            Precio Compra
                            @if (esNuevo) { <span class="text-danger">*</span> }
                        </label>
                        @if (esNuevo)
                        {
                            <input type="number" name="PrecioCompra" value="@Model.PrecioCompra"
                                   class="form-control" required min="0.01" step="0.01" />
                            <small class="text-muted">Precio que paga la farmacia al laboratorio</small>
                        }
                        else
                        {
                            // en edicion el precio de compra es historico y no se puede modificar
                            <input type="text" value="$@Model.PrecioCompra" class="form-control bg-light" disabled />
                            <small class="text-muted">Valor historico, no modificable</small>
                        }
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Stock Mínimo</label>
                        <input type="number" name="StockMinimo" value="@Model.StockMinimo"
                               class="form-control" min="0" />
                    </div>
                </div>

                @if (esNuevo)
                {
                    <div class="mb-3">
                        <label class="form-label">Stock Inicial</label>
                        <input type="number" name="StockActual" value="0"
                               class="form-control" min="0" />
                    </div>
                }

                <div class="mb-3 form-check">
                    <input type="checkbox" name="RequiereReceta" value="true" class="form-check-input"
                           id="chkReceta" @(Model.RequiereReceta ? "checked" : "") />
                    <input type="hidden" name="RequiereReceta" value="false" />
                    <label class="form-check-label" for="chkReceta">Requiere receta médica</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        @(esNuevo ? "Agregar Medicamento" : "Guardar Cambios")
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
