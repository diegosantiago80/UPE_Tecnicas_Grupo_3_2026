@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Ocurrió un error.</h1>
<h2 class="text-danger">Se produjo un error al procesar la solicitud.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>ID de solicitud:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Modo de desarrollo</h3>
<p>
    Cambiar al entorno de <strong>Desarrollo</strong> mostrará información más detallada sobre el error ocurrido.
</p>
<p>
    <strong>El entorno de Desarrollo no debe habilitarse en aplicaciones desplegadas.</strong>
    Puede exponer información sensible de las excepciones a los usuarios finales.
    Para depuración local, habilitá el entorno de <strong>Desarrollo</strong> configurando la variable de entorno <strong>ASPNETCORE_ENVIRONMENT</strong> en <strong>Development</strong>
    y reiniciando la aplicación.
</p>
