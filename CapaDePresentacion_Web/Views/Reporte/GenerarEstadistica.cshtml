@using System
@using System.Collections.Generic
@using CapaDeEntidades;
@model IEnumerable<Reporte>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Estadísticas de Medicamentos";
    // Función para recuperar el parámetro GET de la URL
    string LeerParam(string key)
    {
        if (Context.Request.Query.ContainsKey(key))
            return Context.Request.Query[key].ToString();
        return "";
    }
    string medicamentoBuscado = LeerParam("buscarMedicamento");
    bool seHizoBusqueda = Context.Request.Query.ContainsKey("buscarMedicamento");
    bool hayErrorBackend = ViewBag.ErrorMessage != null || ViewBag.Error != null;
    // Helper para pintar el input de Verde o Rojo tras recargar
    string ObtenerClaseValidacion(string valorCampo)
    {
        if (!seHizoBusqueda) return ""; // Si es la primera vez que entra, nada.
        if (hayErrorBackend) return "is-invalid"; // Si el backend devolvió un error
        return !string.IsNullOrEmpty(valorCampo) ? "is-valid" : "is-invalid"; // Verde si tiene datos, Rojo si lo forzaron vacío por URL
    }
    // Totales calculados
    int totalUnidadesVendidas = 0;
    int totalStockDisponible = 0;
    bool hayDatos = false;
    if (Model != null)
    {
        foreach (var item in Model)
        {
            totalUnidadesVendidas += item.UnidadesVendidas;
            totalStockDisponible += item.StockDisponible;
            hayDatos = true;
        }
    }
}
<div class="container mt-4">
    @* ==================================================================== *@
    @* 1. ALERTA DE ERROR DINÁMICA DEL SERVIDOR                             *@
    @* ==================================================================== *@
    @if (hayErrorBackend)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-start border-danger border-4 d-flex align-items-center mb-4" role="alert">
            <svg class="bi flex-shrink-0 me-2" width="24" height="24" role="img" aria-label="Danger:" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
            </svg>
            <div>
                <strong>¡Atención!</strong> @(ViewBag.ErrorMessage ?? ViewBag.Error)
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <div>
                <h1 class="h4 mb-1 text-primary">Estadísticas de Medicamentos</h1>
                <p class="text-muted small mb-0">Control de unidades vendidas, comparación mensual y disponibilidad en stock</p>
            </div>
            @* ==================================================================== *@
            @* 2. FORMULARIO CON ESTADO VISUAL Y VALIDACIONES                       *@
            @* ==================================================================== *@
            <form method="get" action="@Url.Action("GenerarEstadistica", "Reporte")" class="d-flex gap-2 mb-0" id="formEstadisticas">
                <div class="input-group position-relative">
                    <span class="input-group-text bg-light border-end-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" name="buscarMedicamento"
                           class="form-control border-start-0 w-auto @ObtenerClaseValidacion(medicamentoBuscado)"
                           id="buscarMedicamento" value="@medicamentoBuscado"
                           placeholder="Nombre de medicamento..." title="Buscar por medicamento"
                           maxlength="50" />
                    <!-- Mensaje de error flotante -->
                    <div id="errorMedicamento" class="invalid-feedback" style="font-size: 0.75rem; position: absolute; bottom: -20px; left: 5px; z-index: 5;">
                        Debe ingresar un medicamento.
                    </div>
                </div>
                <button type="submit" class="btn btn-primary px-4">Buscar</button>
            </form>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Medicamento</th>
                            <th class="text-center">Unidades Vendidas</th>
                            <th class="text-center">Comparación Mes Anterior</th>
                            <th class="text-center">Stock Disponible</th>
                            <th class="text-center pe-4">Prioridad de compra</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (hayDatos)
                        {
                            foreach (var item in Model)
                            {
                                // estilos del badge de comparacion de ventas
                                string compClass = "badge bg-light text-muted border px-2 py-1.5 fw-bold";
                                string compIcon = "bi bi-dash";
                                string compSign = "";
                                if (item.PorcentajeVariacion > 0)
                                {
                                    compClass = "badge bg-success-subtle text-success border border-success-subtle px-2 py-1.5 fw-bold";
                                    compIcon = "bi bi-arrow-up-short";
                                    compSign = "+";
                                }
                                else if (item.PorcentajeVariacion < 0)
                                {
                                    compClass = "badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1.5 fw-bold";
                                    compIcon = "bi bi-arrow-down-short";
                                }
                                // estilos del badge de stock
                                string stockClass = "badge bg-success px-3 py-2";
                                string stockLabel = "";
                                if (item.StockDisponible <= 10)
                                {
                                    stockClass = "badge bg-danger px-3 py-2";
                                    stockLabel = " - Crítico";
                                }
                                else if (item.StockDisponible <= 30)
                                {
                                    stockClass = "badge bg-warning text-dark px-3 py-2";
                                    stockLabel = " - Bajo";
                                }
                                // calculo de prioridad de compra (dias de stock restante)
                                int diaActual = DateTime.Today.Day;
                                double ventasDiarias = (double)item.UnidadesVendidas / (diaActual > 0 ? diaActual : 1);
                                double diasDeStockRestante = 999.0;
                                if (ventasDiarias > 0)
                                {
                                    diasDeStockRestante = (double)item.StockDisponible / ventasDiarias;
                                }
                                string prioridadCompra = "No necesario";
                                string prioridadClass = "badge bg-success-subtle text-success border border-success-subtle px-3 py-2 fw-bold";
                                if (diasDeStockRestante <= 7)
                                {
                                    prioridadCompra = "Compra Urgente";
                                    prioridadClass = "badge bg-danger px-3 py-2 fw-bold";
                                }
                                else if (diasDeStockRestante <= 20)
                                {
                                    prioridadCompra = "Soporta Stock";
                                    prioridadClass = "badge bg-warning text-dark px-3 py-2 fw-bold";
                                }
                                <tr>
                                    <td class="fw-semibold ps-4 text-dark">@item.Medicamento</td>
                                    <td class="text-center fw-bold text-secondary">
                                        @item.UnidadesVendidas.ToString("N0")
                                    </td>
                                    <td class="text-center">
                                        <span class="@compClass">
                                            <i class="@compIcon"></i>@compSign@item.PorcentajeVariacion.ToString("0.0")%
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="@stockClass" title="Stock disponible">
                                            @item.StockDisponible<span class="d-none d-sm-inline">@stockLabel</span>
                                        </span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <span class="@prioridadClass" title="Días estimados de stock: @(diasDeStockRestante > 365 ? "Abundante" : diasDeStockRestante.ToString("0.0"))">
                                            @prioridadCompra
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5 fs-6">
                                    <div class="mb-2">
                                        <i class="bi bi-journal-x fs-2 text-secondary"></i>
                                    </div>
                                    No se encontraron estadísticas @(seHizoBusqueda ? "para el medicamento ingresado" : "aún").
                                </td>
                            </tr>
                        }
                    </tbody>
                    @if (hayDatos)
                    {
                        <tfoot class="table-light border-top-2">
                            <tr>
                                <td class="fw-bold py-3 ps-4 text-end text-secondary">Total General:</td>
                                <td class="text-center fw-bold fs-5 py-3 text-primary">
                                    @totalUnidadesVendidas.ToString("N0")
                                </td>
                                <td></td>
                                <td class="text-center fw-bold fs-5 py-3 text-primary">
                                    @totalStockDisponible.ToString("N0")
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const form = document.getElementById('formEstadisticas');
            const inputMedicamento = document.getElementById('buscarMedicamento');
            const feedbackError = document.getElementById('errorMedicamento');
            // Mostrar el borde rojo y texto de error
            function showError(message) {
                inputMedicamento.classList.remove('is-valid');
                inputMedicamento.classList.add('is-invalid');
                feedbackError.textContent = message;
            }
            // Mostrar el borde verde
            function setValid() {
                inputMedicamento.classList.remove('is-invalid');
                inputMedicamento.classList.add('is-valid');
            }
            // Quitar los bordes al escribir
            inputMedicamento.addEventListener('input', function() {
                inputMedicamento.classList.remove('is-invalid', 'is-valid');
            });
            // Lógica al enviar
            form.addEventListener('submit', function(event) {
                let isValid = true;
                const valor = inputMedicamento.value.trim();
                // Limpiar antes de validar
                inputMedicamento.classList.remove('is-invalid', 'is-valid');
                // Validación 1: Vacío
                if (valor === '') {
                    showError('Debe ingresar un medicamento para buscar.');
                    isValid = false;
                }
                // Validación 2: Longitud
                else if (valor.length > 50) {
                    showError('El nombre no puede exceder los 50 caracteres.');
                    isValid = false;
                }
                // Validación 3: Patrón (Sin caracteres raros)
                else {
                    const regex = /^[a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\s\-]+$/;
                    if (!regex.test(valor)) {
                        showError('Solo se permiten letras, números y guiones.');
                        isValid = false;
                    } else {
                        setValid();
                    }
                }
                // Frenar envío si hay errores
                if (!isValid) {
                    event.preventDefault();
                    event.stopPropagation();
                }
            });
        });
    </script>
}