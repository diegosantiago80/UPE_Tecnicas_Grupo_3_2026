@using System
@using System.Collections.Generic
@using CapaDeEntidades

@model IEnumerable<Reporte>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Análisis de Medicamento";

    // helper: lee un parametro primero de query string y si no del form
    string LeerParam(string key)
    {
        if (Context.Request.Query.ContainsKey(key))
            return Context.Request.Query[key].ToString();
        if (Context.Request.HasFormContentType && Context.Request.Form.ContainsKey(key))
            return Context.Request.Form[key].ToString();
        return "";
    }

    string medicamentoBuscado = LeerParam("medicamento");
    string fechaInicioStr = LeerParam("fechaInicio");
    string fechaFinStr = LeerParam("fechaFin");

    bool mostrarAreaAvanzada = !string.IsNullOrEmpty(medicamentoBuscado);

    var ventasOrdenadas = new List<Reporte>();
    int totalCantidades = 0;
    decimal montoTotal = 0;

    if (Model != null)
    {
        foreach (var item in Model)
        {
            ventasOrdenadas.Add(item);
        }
        // ordenamos por fecha para que el analisis evolutivo sea cronologico
        ventasOrdenadas.Sort((a, b) => a.Fecha.CompareTo(b.Fecha));
    }
}

<div class="container mt-4">

    @* ==================================================================== *@
    @* 1. ALERTA DE ERROR DINÁMICA DEL SERVIDOR (BLL / Excepciones)         *@
    @* ==================================================================== *@
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-start border-danger border-4 d-flex align-items-center mb-4" role="alert">
            <svg class="bi flex-shrink-0 me-2" width="24" height="24" role="img" aria-label="Danger:" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
            </svg>
            <div>
                <strong>¡Atención!</strong> @ViewBag.Error
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white py-3">
            <h1 class="h4 mb-4 text-primary">Análisis de Rendimiento por Medicamento</h1>

            @* ==================================================================== *@
            @* 2. FORMULARIO CON INTERCEPTOR DE VALIDACIONES (HTML5 + BOOTSTRAP)     *@
            @* ==================================================================== *@
            <form method="post" action="@Url.Action("Proyeccion", "Reporte")" class="needs-validation" novalidate id="formProyeccion">
                <div class="row align-items-end">

                    @* Campo Medicamento: requerido, sólo letras/espacios y tope de 50 caracteres *@
                    <div class="col-md-4 mb-3 mb-md-0 position-relative">
                        <label class="fw-bold text-muted small text-uppercase" for="medicamento">Medicamento a analizar</label>
                        <input type="text" name="medicamento" id="medicamento" class="form-control"
                               placeholder="Ej. Paracetamol" value="@medicamentoBuscado"
                               pattern="^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s\-]+$" maxlength="50" required />
                        <div class="invalid-feedback" style="font-size: 0.75rem;">
                            Ingrese un nombre válido (letras/espacios, máx. 50 caracteres).
                        </div>
                    </div>

                    @if (mostrarAreaAvanzada)
                    {
                        @* Fecha Inicio (Tope de rango nativo 1900-2100) *@
                        <div class="col-md-3 mb-3 mb-md-0 position-relative">
                            <label class="fw-bold text-muted small text-uppercase" for="fechaInicio">Fecha Inicio</label>
                            <input type="date" name="fechaInicio" id="fechaInicio" class="form-control"
                                   min="1900-01-01" max="2100-12-31" value="@fechaInicioStr" required />
                            <div class="invalid-feedback" id="errorFechaInicio" style="font-size: 0.75rem;">
                                Seleccione una fecha inicial válida (Entre 1900 y 2100).
                            </div>
                        </div>

                        @* Fecha Fin *@
                        <div class="col-md-3 mb-3 mb-md-0 position-relative">
                            <label class="fw-bold text-muted small text-uppercase" for="fechaFin">Fecha Fin</label>
                            <input type="date" name="fechaFin" id="fechaFin" class="form-control"
                                   min="1900-01-01" max="2100-12-31" value="@fechaFinStr" required />
                            <div class="invalid-feedback" id="errorFechaFin" style="font-size: 0.75rem;">
                                Seleccione una fecha final válida (Entre 1900 y 2100).
                            </div>
                        </div>
                    }

                    <div class="col-md-2 mt-3 mt-md-0">
                        <button type="submit" class="btn btn-primary w-100">Analizar</button>
                    </div>
                </div>
            </form>
        </div>

        @if (mostrarAreaAvanzada)
        {
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Fecha de Venta</th>
                                <th class="text-center">Cantidad Vendida</th>
                                <th class="text-end">Monto Actual</th>
                                <th class="text-end">Monto Anterior</th>
                                <th class="text-center">Crecimiento / Caída</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                decimal montoAnterior = 0;
                                bool existenDatos = false;

                                foreach (var venta in ventasOrdenadas)
                                {
                                    existenDatos = true;
                                    int cantidadReal = venta.UnidadesVendidas > 0 ? venta.UnidadesVendidas : 1;

                                    totalCantidades += cantidadReal;
                                    montoTotal += venta.Monto;
                                    decimal porcentaje = 0;
                                    string colorClase = "text-muted";
                                    string signo = "";

                                    if (montoAnterior > 0)
                                    {
                                        porcentaje = ((venta.Monto - montoAnterior) / montoAnterior) * 100;

                                        if (porcentaje > 0)
                                        {
                                            colorClase = "text-success";
                                            signo = "+";
                                        }
                                        else if (porcentaje < 0)
                                        {
                                            colorClase = "text-danger";
                                        }
                                    }

                                    <tr>
                                        <td>@venta.Fecha.ToString("dd/MM/yyyy")</td>
                                        <td class="text-center">@cantidadReal</td>
                                        <td class="text-end fw-bold">@venta.Monto.ToString("C")</td>
                                        <td class="text-end text-muted">
                                            @(montoAnterior == 0 ? "-" : montoAnterior.ToString("C"))
                                        </td>
                                        <td class="text-center fw-bold @colorClase">
                                            @(montoAnterior == 0 ? "Sin historial" : $"{signo}{porcentaje.ToString("0.00")}%")
                                        </td>
                                    </tr>

                                    montoAnterior = venta.Monto;
                                }

                                if (!existenDatos)
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            No hay registros de ventas para "@medicamentoBuscado" en este período.
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>

                        @if (ventasOrdenadas.Count > 0)
                        {
                            <tfoot class="table-light">
                                <tr>
                                    <td class="text-end fw-bold py-3">Totales del Período:</td>
                                    <td class="text-center fw-bold fs-5 text-primary py-3">@totalCantidades</td>
                                    <td class="text-end fw-bold fs-5 text-success py-3">@montoTotal.ToString("C")</td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="card-body text-center py-5">
                <i class="bi bi-sliders2 fs-1 text-muted d-block mb-3"></i>
                <p class="text-muted mb-0">Por favor, ingresa el nombre de un medicamento para comenzar el análisis.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const form = document.getElementById('formProyeccion');
            const fechaInicio = document.getElementById('fechaInicio');
            const fechaFin = document.getElementById('fechaFin');
            const errorFechaInicio = document.getElementById('errorFechaInicio');
            const errorFechaFin = document.getElementById('errorFechaFin');

            if (form) {
                form.addEventListener('submit', function(event) {
                    let esValido = true;

                    // --- FUNCIÓN HELPER PARA VALIDAR EL AÑO ---
                    function validarAnioCoherente(inputElement, errorElement) {
                        if (!inputElement || !inputElement.value) return true;

                        const fechaObj = new Date(inputElement.value);
                        const anio = fechaObj.getFullYear();

                        // Captura si el año no tiene 4 dígitos o está fuera de un rango real
                        if (isNaN(anio) || anio < 1900 || anio > 2100 || inputElement.value.split("-")[0].length !== 4) {
                            inputElement.setCustomValidity("Año Invalido");
                            errorElement.textContent = "Por favor, introduzca un año de 4 dígitos entre 1900 y 2100.";
                            return false;
                        }
                        inputElement.setCustomValidity("");
                        return true;
                    }

                    // 1. Validar coherencia de años de manera individual
                    const anioInicioValido = validarAnioCoherente(fechaInicio, errorFechaInicio);
                    const anioFinValido = validarAnioCoherente(fechaFin, errorFechaFin);

                    if (!anioInicioValido || !anioFinValido) {
                        esValido = false;
                    }

                    // 2. Validación cruzada de fechas (Solo si los años individuales pasaron el filtro)
                    if (esValido && fechaInicio && fechaFin && fechaInicio.value && fechaFin.value) {
                        const fInicio = new Date(fechaInicio.value);
                        const fFin = new Date(fechaFin.value);

                        if (fFin < fInicio) {
                            esValido = false;
                            fechaFin.setCustomValidity("Rango Invalido");
                            errorFechaFin.textContent = "La fecha de fin no puede ser anterior a la fecha de inicio.";
                        }
                    }

                    // Frena el Submit si cualquiera de las validaciones de negocio falló
                    if (!form.checkValidity() || !esValido) {
                        event.preventDefault();
                        event.stopPropagation();
                    }

                    form.classList.add('was-validated');
                }, false);

                // Resetea los custom errors al escribir de nuevo
                if (fechaInicio && fechaFin) {
                    fechaInicio.addEventListener('input', () => {
                        fechaInicio.setCustomValidity("");
                        fechaFin.setCustomValidity("");
                    });
                    fechaFin.addEventListener('input', () => {
                        fechaFin.setCustomValidity("");
                    });
                }
            }
        });
    </script>
}