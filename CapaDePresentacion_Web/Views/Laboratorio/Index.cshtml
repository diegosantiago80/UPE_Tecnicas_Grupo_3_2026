@model IEnumerable<CapaDeEntidades.Laboratorio>

@{
    ViewData["Title"] = "Gestión de Laboratorios";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Laboratorios Proveedores</h1>
        <a asp-action="Gestionar" class="btn btn-primary">+ Nuevo Laboratorio</a>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <table class="table table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Razón Social</th>
                <th>CUIT</th>
                <th>Teléfono</th>
                <th>Email</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.IdLaboratorio</td>
                    <td><strong>@item.RazonSocial</strong></td>
                    <td>@item.Cuit</td>
                    <td>@item.Telefono</td>
                    <td>@item.Email</td>
                    <td>
                        @if (item.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Gestionar" asp-route-id="@item.IdLaboratorio" class="btn btn-sm btn-outline-primary">Editar</a>
                        @if (item.Activo)
                        {
                            <form asp-action="DarDeBaja" method="post" class="d-inline form-baja">
                                <input type="hidden" name="id" value="@item.IdLaboratorio" />
                                <button type="button" class="btn btn-sm btn-outline-danger btn-confirmar-baja"
                                        data-nombre="@item.RazonSocial">Dar de baja</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".btn-confirmar-baja").forEach(btn => {
            btn.addEventListener("click", function () {
                const nombre = this.dataset.nombre;
                const form = this.closest("form");
                Swal.fire({
                    icon: "warning",
                    title: "¿Dar de baja?",
                    html: `Esta acción desactivará a <strong>${nombre}</strong>.`,
                    showCancelButton: true,
                    confirmButtonText: "Sí, dar de baja",
                    cancelButtonText: "Cancelar",
                    confirmButtonColor: "#dc3545",
                    cancelButtonColor: "#6c757d"
                }).then(result => {
                    if (result.isConfirmed) form.submit();
                });
            });
        });
    </script>
}
