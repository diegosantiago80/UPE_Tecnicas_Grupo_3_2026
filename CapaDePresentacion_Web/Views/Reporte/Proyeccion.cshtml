@using System
@using System.Collections.Generic
@using System.Linq
@using CapaDeEntidades


@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Análisis de Medicamento";

    // Intentamos leer los valores enviados por la URL (si los hay)
    // Usamos string vacío como default para evitar errores nulos
    string medicamentoBuscado = "";
    string fechaInicioStr = "";
    string fechaFinStr = "";

    // Verificamos si la petición tiene datos en el QueryString
    if (Context.Request.Query.ContainsKey("medicamento"))
    {
        medicamentoBuscado = Context.Request.Query["medicamento"].ToString();
    }
    if (Context.Request.Query.ContainsKey("fechaInicio"))
    {
        fechaInicioStr = Context.Request.Query["fechaInicio"].ToString();
    }
    if (Context.Request.Query.ContainsKey("fechaFin"))
    {
        fechaFinStr = Context.Request.Query["fechaFin"].ToString();
    }

    // Solo mostramos las fechas y la tabla si el usuario ya buscó un medicamento
    bool mostrarAreaAvanzada = !string.IsNullOrEmpty(medicamentoBuscado);

    // Declaramos las variables globales para la tabla aquí arriba para evitar problemas de alcance (scope)
    var ventasOrdenadas = new List<Reporte>();
    int totalCantidades = 0;
    decimal montoTotal = 0;

    // Si hay datos en el modelo, los pasamos a la lista fuerte y los ordenamos sin usar LINQ
    if (Model != null)
    {
        foreach (var item in Model)
        {
            ventasOrdenadas.Add(item);
        }
        // Usamos el Sort clásico para evitar errores dinámicos de ASP.NET
        ventasOrdenadas.Sort((a, b) => a.Fecha.CompareTo(b.Fecha));
    }
}

<!-- CONTENEDOR PRINCIPAL -->
<div class="container mt-4">

    <div class="card shadow-sm border-0">

        <!-- CABECERA DE BÚSQUEDA -->
        <div class="card-header bg-white py-3">
            <h1 class="h4 mb-4 text-primary">Análisis de Rendimiento por Medicamento</h1>

            <form method="get">
                <!-- Usamos row clásico para máxima compatibilidad con cualquier versión de Bootstrap -->
                <div class="row align-items-end">

                    <!-- PASO 1: Campo Medicamento -->
                    <div class="col-md-4 mb-3 mb-md-0">
                        <label class="fw-bold font-weight-bold text-muted small text-uppercase">Medicamento a analizar</label>
                        <input type="text" name="medicamento" class="form-control" placeholder="Ej. Paracetamol" value="@medicamentoBuscado" required />
                    </div>

                    <!-- PASO 2: Área de fechas (Se habilita posterior a la primera búsqueda) -->
                    @if (mostrarAreaAvanzada)
                    {
                        <div class="col-md-3 mb-3 mb-md-0">
                            <label class="fw-bold font-weight-bold text-muted small text-uppercase">Fecha Inicio</label>
                            <input type="date" name="fechaInicio" class="form-control" value="@fechaInicioStr" />
                        </div>
                        <div class="col-md-3 mb-3 mb-md-0">
                            <label class="fw-bold font-weight-bold text-muted small text-uppercase">Fecha Fin</label>
                            <input type="date" name="fechaFin" class="form-control" value="@fechaFinStr" />
                        </div>
                    }

                    <div class="col-md-2 mt-3 mt-md-0">
                        <button type="submit" class="btn btn-primary w-100 btn-block">Buscar</button>
                    </div>
                </div>
            </form>
        </div>

        <!-- TABLA DE RESULTADOS COMPARATIVOS -->
        @if (mostrarAreaAvanzada)
        {
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Fecha de Venta</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Monto Actual</th>
                                <th class="text-end">Monto Anterior</th>
                                <th class="text-center">Crecimiento / Caída</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                decimal montoAnterior = 0;
                                bool existenDatos = false;

                                foreach (var venta in ventasOrdenadas)
                                {
                                    existenDatos = true;

                                    // Generamos una cantidad "hardcodeada" simulada basada en el monto para evitar errores de compilación
                                    // si tu clase Reporte no tiene la propiedad Cantidad.
                                    int cantidadSimulada = (int)(venta.Monto / 50) + 1;

                                    totalCantidades += cantidadSimulada; // Acumulamos la cantidad simulada
                                    montoTotal += venta.Monto;         // Acumulamos el monto

                                    decimal porcentaje = 0;
                                    string colorClase = "text-muted";
                                    string signo = "";

                                    // Si existe un monto previo, calculamos la diferencia porcentual
                                    if (montoAnterior > 0)
                                    {
                                        porcentaje = ((venta.Monto - montoAnterior) / montoAnterior) * 100;

                                        if (porcentaje > 0)
                                        {
                                            colorClase = "text-success"; // Verde para crecimiento
                                            signo = "+";
                                        }
                                        else if (porcentaje < 0)
                                        {
                                            colorClase = "text-danger"; // Rojo para caída
                                        }
                                    }

                                    <tr>
                                        <td>@venta.Fecha.ToString("dd/MM/yyyy")</td>
                                        <td class="text-center">@cantidadSimulada</td>
                                        <td class="text-end fw-bold">@venta.Monto.ToString("C")</td>
                                        <td class="text-end text-muted">
                                            @(montoAnterior == 0 ? "-" : montoAnterior.ToString("C"))
                                        </td>
                                        <td class="text-center fw-bold font-weight-bold @colorClase">
                                            @(montoAnterior == 0 ? "Sin historial" : $"{signo}{porcentaje.ToString("0.00")}%")
                                        </td>
                                    </tr>

                                    // Guardamos el monto actual para que sea el "anterior" en la próxima vuelta del bucle
                                    montoAnterior = venta.Monto;
                                }

                                if (!existenDatos)
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            No hay registros de ventas para "@medicamentoBuscado" en este período.
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>

                        @* Agregamos el pie de tabla revisando el contador de la lista (sin usar .Any()) *@
                        @if (ventasOrdenadas.Count > 0)
                        {
                            <tfoot class="table-light">
                                <tr>
                                    <td class="text-end fw-bold py-3">Totales del Período:</td>
                                    <td class="text-center fw-bold fs-5 text-primary py-3">@totalCantidades</td>
                                    <td class="text-end fw-bold fs-5 text-success py-3">@montoTotal.ToString("C")</td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>
        }
        else
        {
            <!-- Estado vacío antes de buscar -->
            <div class="card-body text-center py-5">
                <p class="text-muted mb-0">Por favor, ingresa el nombre de un medicamento para comenzar el análisis.</p>
            </div>
        }
    </div>
</div>


