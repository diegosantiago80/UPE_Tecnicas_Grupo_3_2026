@using Microsoft.AspNetCore.Http
@using CapaDeLogicaDeNegocio_BLL
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Inicio";

    var auth = AuthService.Instance;
    var nombreParaMostrar = HttpContextAccessor.HttpContext.Session.GetString("NombreUsuario");
    var idPerfil = HttpContextAccessor.HttpContext.Session.GetInt32("IdPerfil");
    var nombreRol = HttpContextAccessor.HttpContext.Session.GetString("NombreRol");

    // color del badge segun perfil
    string badgeColor = idPerfil switch {
        1 => "warning text-dark",
        2 => "success",
        3 => "primary",
        4 => "info text-dark",
        _ => "secondary"
    };
}

<div class="container mt-4">

    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="mb-1">Bienvenido/a, <strong>@nombreParaMostrar</strong></h2>
            <p class="text-muted mb-0">
                <span class="badge bg-@badgeColor me-1">@nombreRol</span>
                El menú está adaptado a sus permisos.
            </p>
        </div>
        <i class="bi bi-capsule-pill text-primary" style="font-size: 3rem; opacity: 0.15;"></i>
    </div>

    <div class="row g-3">

        @if (auth.PerfilTienePermiso(idPerfil, "RegistrarVenta"))
        {
            <div class="col-sm-6 col-lg-4">
                <a asp-controller="Venta" asp-action="Registrar" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body d-flex align-items-center gap-3 p-4">
                            <div class="rounded-3 p-3 bg-success bg-opacity-10">
                                <i class="bi bi-cart-check-fill fs-3 text-success"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Registrar Venta</h6>
                                <p class="mb-0 text-muted small">Procesar venta a cliente</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }

        @if (auth.PerfilTienePermiso(idPerfil, "GestionarClientes"))
        {
            <div class="col-sm-6 col-lg-4">
                <a asp-controller="Cliente" asp-action="Gestionar" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body d-flex align-items-center gap-3 p-4">
                            <div class="rounded-3 p-3 bg-primary bg-opacity-10">
                                <i class="bi bi-people-fill fs-3 text-primary"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Clientes</h6>
                                <p class="mb-0 text-muted small">Alta y modificación de clientes</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            //prueba
            <div class="col-sm-6 col-lg-4">
                <a asp-controller="Cliente" asp-action="Listar" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body d-flex align-items-center gap-3 p-4">
                            <div class="rounded-3 p-3 bg-info bg-opacity-10">
                                <i class="bi bi-person-lines-fill fs-3 text-info"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Listado de Clientes</h6>
                                <p class="mb-0 text-muted small">Ver clientes ordenados por apellido</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>

            //fin prueba
        }

        @if (auth.PerfilTienePermiso(idPerfil, "ControlStock"))
        {
            <div class="col-sm-6 col-lg-4">
                <a asp-controller="Medicamento" asp-action="Index" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body d-flex align-items-center gap-3 p-4">
                            <div class="rounded-3 p-3 bg-warning bg-opacity-10">
                                <i class="bi bi-bar-chart-line-fill fs-3 text-warning"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Control de Stock</h6>
                                <p class="mb-0 text-muted small">Ver stock y alertas de medicamentos</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }

        @if (auth.PerfilTienePermiso(idPerfil, "RegistrarCompra"))
        {
            <div class="col-sm-6 col-lg-4">
                <a asp-controller="Compra" asp-action="Registrar" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body d-flex align-items-center gap-3 p-4">
                            <div class="rounded-3 p-3 bg-info bg-opacity-10">
                                <i class="bi bi-truck fs-3 text-info"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Registrar Compra</h6>
                                <p class="mb-0 text-muted small">Ingreso de mercadería al stock</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }

        @if (auth.PerfilTienePermiso(idPerfil, "GestionarMedicamentos"))
        {
            <div class="col-sm-6 col-lg-4">
                <a asp-controller="Medicamento" asp-action="Gestionar" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body d-flex align-items-center gap-3 p-4">
                            <div class="rounded-3 p-3 bg-secondary bg-opacity-10">
                                <i class="bi bi-capsule fs-3 text-secondary"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Medicamentos</h6>
                                <p class="mb-0 text-muted small">ABM de productos del catálogo</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }

        @if (auth.PerfilTienePermiso(idPerfil, "GestionarLaboratorios"))
        {
            <div class="col-sm-6 col-lg-4">
                <a asp-controller="Laboratorio" asp-action="Index" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body d-flex align-items-center gap-3 p-4">
                            <div class="rounded-3 p-3 bg-dark bg-opacity-10">
                                <i class="bi bi-building fs-3 text-dark"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Laboratorios</h6>
                                <p class="mb-0 text-muted small">Gestión de proveedores</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }

        @if (auth.PerfilTienePermiso(idPerfil, "VerReporte"))
        {
            <div class="col-sm-6 col-lg-4">
                <a asp-controller="Reporte" asp-action="VerReporte" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body d-flex align-items-center gap-3 p-4">
                            <div class="rounded-3 p-3 bg-success bg-opacity-10">
                                <i class="bi bi-receipt fs-3 text-success"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Reporte de Ventas</h6>
                                <p class="mb-0 text-muted small">Ventas por período y vendedor</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }

        @if (auth.PerfilTienePermiso(idPerfil, "GenerarEstadisticas"))
        {
            <div class="col-sm-6 col-lg-4">
                <a asp-controller="Reporte" asp-action="GenerarEstadistica" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body d-flex align-items-center gap-3 p-4">
                            <div class="rounded-3 p-3 bg-primary bg-opacity-10">
                                <i class="bi bi-bar-chart-fill fs-3 text-primary"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Estadísticas</h6>
                                <p class="mb-0 text-muted small">Análisis de medicamentos vendidos</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }

        @if (auth.PerfilTienePermiso(idPerfil, "GenerarProyeccion"))
        {
            <div class="col-sm-6 col-lg-4">
                <a asp-controller="Reporte" asp-action="Proyeccion" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body d-flex align-items-center gap-3 p-4">
                            <div class="rounded-3 p-3 bg-info bg-opacity-10">
                                <i class="bi bi-graph-up-arrow fs-3 text-info"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Proyecciones</h6>
                                <p class="mb-0 text-muted small">Evolución de ventas por producto</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }

        @if (auth.PerfilTienePermiso(idPerfil, "GestionarUsuarios"))
        {
            <div class="col-sm-6 col-lg-4">
                <a asp-controller="Usuarios" asp-action="Index" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body d-flex align-items-center gap-3 p-4">
                            <div class="rounded-3 p-3 bg-warning bg-opacity-10">
                                <i class="bi bi-person-gear fs-3 text-warning"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Usuarios</h6>
                                <p class="mb-0 text-muted small">Alta y gestión de operadores</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }

        @if (auth.PerfilTienePermiso(idPerfil, "ConfigurarPerfiles"))
        {
            <div class="col-sm-6 col-lg-4">
                <a asp-controller="Perfiles" asp-action="Index" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body d-flex align-items-center gap-3 p-4">
                            <div class="rounded-3 p-3 bg-warning bg-opacity-10">
                                <i class="bi bi-shield-lock fs-3 text-warning"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Perfiles</h6>
                                <p class="mb-0 text-muted small">Configuración de permisos por rol</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }

        @if (auth.PerfilTienePermiso(idPerfil, "ConsultarLog"))
        {
            <div class="col-sm-6 col-lg-4">
                <a asp-controller="Auditoria" asp-action="Index" class="text-decoration-none">
                    <div class="card border-0 shadow-sm h-100 card-hover">
                        <div class="card-body d-flex align-items-center gap-3 p-4">
                            <div class="rounded-3 p-3 bg-warning bg-opacity-10">
                                <i class="bi bi-journal-text fs-3 text-warning"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">Consultar Auditoría</h6>
                                <p class="mb-0 text-muted small">Supervisión de actividades</p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }

    </div>
</div>

@section Styles {
    <style>
        .card-hover {
            transition: transform 0.15s ease, box-shadow 0.15s ease;
            cursor: pointer;
        }
        .card-hover:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.12) !important;
        }
    </style>
}
