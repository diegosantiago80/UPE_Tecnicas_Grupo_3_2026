@{
    ViewData["Title"] = "Registrar Compra a Laboratorio";
    var laboratorios = ViewBag.Laboratorios as List<CapaDeEntidades.Laboratorio>;
    var medicamentos = ViewBag.Medicamentos as List<CapaDeEntidades.Medicamento>;
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4><i class="bi bi-cart-plus"></i> Nueva Compra de Mercadería</h4>
        </div>
        <div class="card-body">
            <form id="formCompra">
                <div class="row mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Seleccionar Laboratorio</label>
                        <select class="form-select" id="idLaboratorio" required>
                            <option value="">-- Seleccione un proveedor --</option>
                            @foreach (var lab in laboratorios)
                            {
                                <option value="@lab.IdLaboratorio">@lab.RazonSocial (@lab.Cuit)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6 text-end">
                        <label class="form-label fw-bold">Fecha de Operación</label>
                        <input type="text" class="form-control text-center" value="@DateTime.Now.ToShortDateString()" disabled />
                    </div>
                </div>

                <hr />

                <div class="row g-3 align-items-end mb-4">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Producto</label>
                        <select class="form-select" id="idMedicamento">
                            <option value="">-- Seleccione Medicamento --</option>
                            @foreach (var med in medicamentos)
                            {
                                <option value="@med.IdMedicamento" data-precio="@med.PrecioCompra">@med.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold">Cantidad</label>
                        <input type="number" id="cantidad" class="form-control" min="1" value="1" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Precio Unitario</label>
                        <input type="number" id="precioUnitario" class="form-control" min="0.01" step="0.01" value="0" />
                        <small id="avisoPrecio" class="text-warning d-none">
                            Este medicamento no tiene precio de compra cargado. Ingresalo manualmente.
                        </small>
                    </div>
                    <div class="col-md-3">
                        <button type="button" class="btn btn-success w-100" id="btnAgregar">
                            <i class="bi bi-plus-circle"></i> Agregar
                        </button>
                    </div>
                </div>

                <table class="table table-bordered table-striped mt-3" id="tablaDetalle">
                    <thead class="table-secondary">
                        <tr>
                            <th>Producto</th>
                            <th class="text-center">Cantidad</th>
                            <th class="text-center">Precio Unit.</th>
                            <th class="text-center">Subtotal</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @* las filas se agregan dinamicamente desde el script de abajo *@
                    </tbody>
                </table>

                <div class="d-flex justify-content-between align-items-center mt-4">
                    <h5>Total: <strong id="totalCompra">$0.00</strong></h5>
                    <button type="button" class="btn btn-primary btn-lg" id="btnFinalizar">
                        Confirmar y Actualizar Stock
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        // detalle de la compra que se arma del lado del cliente antes de enviar
        let detalleCompra = [];

        // precarga el precio de compra al seleccionar un medicamento
        document.getElementById("idMedicamento").addEventListener("change", function () {
            const opt = this.options[this.selectedIndex];
            const precio = parseFloat(opt.dataset.precio ?? "0");
            document.getElementById("precioUnitario").value = precio;

            // aviso si el precio de compra del medicamento es 0
            const aviso = document.getElementById("avisoPrecio");
            if (precio === 0 && this.value !== "") {
                aviso.classList.remove("d-none");
            } else {
                aviso.classList.add("d-none");
            }
        });

        document.getElementById("btnAgregar").addEventListener("click", function () {
            const selectMed    = document.getElementById("idMedicamento");
            const idMed        = selectMed.value;
            const nombreMed    = selectMed.options[selectMed.selectedIndex].text;
            const cant         = parseInt(document.getElementById("cantidad").value);
            const precioUnit   = parseFloat(document.getElementById("precioUnitario").value);

            if (!idMed)          { alert("Seleccione un medicamento"); return; }
            if (cant <= 0)       { alert("La cantidad debe ser mayor a 0"); return; }
            if (precioUnit <= 0) { alert("El precio unitario debe ser mayor a 0"); return; }

            // evitar duplicados — si ya esta lo reemplaza
            detalleCompra = detalleCompra.filter(x => x.IdMedicamento != parseInt(idMed));

            detalleCompra.push({
                IdMedicamento:  parseInt(idMed),
                Cantidad:       cant,
                PrecioUnitario: precioUnit
            });

            const subtotal = (cant * precioUnit).toFixed(2);
            const tbody = document.getElementById("tablaDetalle").getElementsByTagName('tbody')[0];
            const nuevaFila = tbody.insertRow();
            nuevaFila.dataset.idMed = idMed;
            nuevaFila.innerHTML = `
                <td>${nombreMed}</td>
                <td class="text-center">${cant}</td>
                <td class="text-center">$${precioUnit.toFixed(2)}</td>
                <td class="text-center">$${subtotal}</td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-danger" onclick="eliminarFila(this, ${idMed})">Eliminar</button>
                </td>
            `;

            selectMed.selectedIndex = 0;
            document.getElementById("cantidad").value = 1;
            document.getElementById("precioUnitario").value = 0;
            actualizarTotal();
        });

        function eliminarFila(btn, id) {
            detalleCompra = detalleCompra.filter(x => x.IdMedicamento != id);
            const fila = btn.closest('tr');
            fila.parentNode.removeChild(fila);
            actualizarTotal();
        }

        function actualizarTotal() {
            const total = detalleCompra.reduce((acc, x) => acc + (x.Cantidad * x.PrecioUnitario), 0);
            const el = document.getElementById("totalCompra");
            if (el) el.textContent = "$" + total.toFixed(2);
        }

        document.getElementById("btnFinalizar").addEventListener("click", function () {
            const idLab = document.getElementById("idLaboratorio").value;

            if (!idLab)                  { alert("Debe seleccionar un laboratorio"); return; }
            if (detalleCompra.length === 0) { alert("Debe agregar al menos un producto"); return; }

            // armar el DTO completo
            const request = {
                IdLaboratorio: parseInt(idLab),
                Items: detalleCompra
            };

            fetch('/Compra/Procesar', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(request)
            })
            .then(async response => {
                if (response.ok) {
                    alert("Compra registrada correctamente. El stock fue actualizado.");
                    window.location.href = '/Medicamento/Index';
                } else {
                    const msg = await response.text();
                    alert("Error al procesar la compra: " + msg);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert("Error de red o conexion.");
            });
        });
    </script>
}