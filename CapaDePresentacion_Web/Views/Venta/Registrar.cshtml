@{
    ViewData["Title"] = "Registrar Venta";
    var medicamentos = ViewBag.Medicamentos as List<CapaDeEntidades.Medicamento> ?? new List<CapaDeEntidades.Medicamento>();
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h4><i class="bi bi-cash-stack"></i> Registrar Venta de Farmacia</h4>
        </div>
        <div class="card-body">
            <form id="formVenta">
                <div class="row mb-4 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">DNI Cliente</label>
                        <input type="text" id="dniCliente" class="form-control" required
                               pattern="\d+"
                               title="Ingrese solo números"
                               maxlength="8" minlength="8">
                    </div>
                    <div class="col-md-5">
                        <label class="form-label fw-bold">Nombre del Cliente</label>
                        <input type="text" id="nombreCliente" class="form-control" style="background-color: #e9ecef; font-weight: bold;" readonly placeholder="Esperando DNI...">
                    </div>
                    <div class="col-md-2">

                        <label class="form-label fw-bold">Fecha</label>
                        <input type="text" class="form-control text-center" value="@DateTime.Now.ToShortDateString()" disabled />
                    </div>

                    <div class="col-md-2">
                        <label class="form-label fw-bold">Cobro</label>
                        <select class="form-select" id="tipoDescuento" disabled>
                            <option value="Particular">Particular</option>
                            <option value="ObraSocial">Obra Social</option>
                        </select>
                    </div>
                </div>

                <hr />

              
                <div class="row g-3 align-items-end mb-4">
                    <div class="col-md-5">
                        <label class="form-label fw-bold">Medicamento</label>
                        <div style="position: relative;">
                            <input type="text" id="buscarMedicamento" class="form-control"
                                   placeholder="Escribí 3 letras para buscar..." autocomplete="off">
                            <div id="listaMedicamentos" style="
                            display: none;
                            position: absolute;
                            top: 100%;
                            left: 0; right: 0;
                            background: white;
                            border: 1px solid #ced4da;
                            border-radius: 0 0 4px 4px;
                            max-height: 220px;
                            overflow-y: auto;
                            z-index: 9999;
                            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
                            "></div>
                        </div>
                        
                        <input type="hidden" id="idMedicamento">
                        <input type="hidden" id="dataReceta">
                        <input type="hidden" id="dataPrecio">
                        <input type="hidden" id="dataStock">

                        
                        <select id="opcionesOriginales" style="display:none;">
                            @foreach (var med in medicamentos)
                            {
                                <option value="@med.IdMedicamento"
                                        data-receta="@med.RequiereReceta"
                                        data-precio="@med.PrecioVenta"
                                        data-stock="@med.StockActual">
                                    @med.Nombre (@med.Descripcion) - Stock: @med.StockActual
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold">Cantidad</label>
                        <input type="number" id="cantidad" class="form-control" min="1" value="1" />
                    </div>
                    <div class="col-md-2 text-center">
                        <div class="form-check mb-2 d-inline-block text-start">
                            <input class="form-check-input" type="checkbox" id="checkReceta">
                            <label class="form-check-label" for="checkReceta">Tiene Receta</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <button type="button" class="btn btn-primary w-100" id="btnAgregar">Agregar</button>
                    </div>
                </div>

               
                <table class="table table-bordered" id="tablaDetalle">
                    <thead class="table-light">
                        <tr>
                            <th>Medicamento</th>
                            <th class="text-center">Cant.</th>
                            <th class="text-end">Unitario</th>
                            <th class="text-end">Subtotal</th>
                            <th class="text-center">Eliminar</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>

                <div class="text-end mt-3">
                    <h5 class="text-muted">Subtotal Bruto: <span id="txtSubtotalBruto">$ 0.00</span></h5>

                    <div id="avisoVentaLibre" class="text-danger fw-bold mb-2" style="display: none;">
                        <i class="bi bi-exclamation-triangle"></i> Venta libre: No aplica descuento.
                    </div>

                    <h3 class="text-success">Total a Cobrar: <span id="txtTotalFinal">$ 0.00</span></h3>
                    <button type="button" class="btn btn-success btn-lg mt-2" id="btnFinalizar">Confirmar Venta</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let itemsVenta = [];

        const EstrategiasDescuento = {
            "ObraSocial": (subtotal, requiereReceta) => {
                return requiereReceta ? (subtotal * 0.60) : subtotal;
            },
            "Particular": (subtotal, requiereReceta) => {
                return subtotal;
            }
        };

        
        document.getElementById("dniCliente").addEventListener("input", async function() {
            const dni = this.value.trim();
            const txtNombre = document.getElementById("nombreCliente");
            const selectorCobro = document.getElementById("tipoDescuento");

            if (dni === "") {
                txtNombre.value = "";
                return;
            }

            if (!this.checkValidity()) {
                this.reportValidity(); 
                return; 
            }

            if (dni.length > 7 && dni.length <= 11) {
                const resp = await fetch(`/Cliente/ObtenerPorDni?dni=${dni}`);
                const res = await resp.json();

                if (res.success) {

                    if (res.data.activo === false) {
                        alert("Es un cliente inactivo, no puede realizar una compra.");
                        txtNombre.value = "CLIENTE INACTIVO";
                        txtNombre.style.color = "red";
                        this.value = "";
                        selectorCobro.value = "Particular";
                        return; 
                    }


                    txtNombre.value = res.data.nombre + " " + res.data.apellido;
                    txtNombre.style.color = "blue";
                    selectorCobro.value = (res.data.obraSocial === "Particular") ? "Particular" : "ObraSocial";
                    actualizarTotales(); 
                } else {
                    txtNombre.value = "CLIENTE NO ENCONTRADO";
                    txtNombre.style.color = "red"; 
                    if (confirm("El cliente no está registrado. ¿Desea darlo de alta ahora?")) {
                        window.location.href = "/Cliente/Gestionar";
                    }
                }
            }
        });

        
              document.getElementById("btnAgregar").addEventListener("click", function() {
            const idMed = document.getElementById("idMedicamento").value;
            const nombreCompleto = document.getElementById("buscarMedicamento").value;
            const dni = document.getElementById("dniCliente").value;

            if (!dni) return alert("Ingrese el DNI del cliente primero.");
            if (!idMed) return alert("Seleccione un producto usando el buscador.");

           const cant = parseInt(document.getElementById("cantidad").value);
           const stock = parseInt(document.getElementById("dataStock").value);

            if (cant > stock) return alert("❌ Producto sin stock."); // Se emite el mensaje 05

            const requiereReceta = document.getElementById("dataReceta").value === "True";
            const tieneReceta = document.getElementById("checkReceta").checked;

            if (requiereReceta && !tieneReceta) {
                return alert("⚠️ Este medicamento requiere receta obligatoria."); // Se emite el mensaje 06
            }

            const item = {
                id: parseInt(idMed),
                nombre: nombreCompleto.substring(0, nombreCompleto.indexOf("- Stock")).trim() || nombreCompleto,
                cantidad: cant,
                precio: parseFloat(document.getElementById("dataPrecio").value) || 0,
                requiereReceta: requiereReceta
            };

            itemsVenta.push(item);
            renderizarTabla();
            actualizarTotales();

            document.getElementById("idMedicamento").value = "";
            document.getElementById("dataReceta").value = "";
            document.getElementById("dataPrecio").value = "";
            document.getElementById("dataStock").value = "";
            document.getElementById("buscarMedicamento").value = "";
            document.getElementById("cantidad").value = 1;
            document.getElementById("checkReceta").checked = false;
        });

        function renderizarTabla() {
            const tbody = document.querySelector("#tablaDetalle tbody");
            const tipoCobro = document.getElementById("tipoDescuento").value;
            tbody.innerHTML = "";

            itemsVenta.forEach((item, index) => {
                const subtotalBruto = item.precio * item.cantidad;
                const calcular = EstrategiasDescuento[tipoCobro];
                const subtotalNeto = calcular(subtotalBruto, item.requiereReceta);
                const tieneDescuento = subtotalNeto < subtotalBruto;
                const etiqueta = tieneDescuento
                    ? `<span class="badge bg-success">DTO. OS (40%)</span>`
                    : `<span class="badge bg-secondary">SIN DTO.</span>`;

                const fila = `<tr>
                                            <td>
                                                ${item.nombre} <br>
                                                <small class="text-muted">${item.requiereReceta ? 'Bajo Receta' : 'Venta Libre'}</small>
                                            </td>
                                           <td class="text-center">${item.cantidad} ✅</td>
                                            <td class="text-end">$ ${item.precio.toFixed(2)}</td>
                                            <td class="text-end">
                                                <div>$ ${subtotalNeto.toFixed(2)}</div>
                                                <div>${etiqueta}</div>
                                            </td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-danger btn-sm" onclick="eliminarFila(${index})">X</button>
                                            </td>
                                        </tr>`;
                tbody.innerHTML += fila;
            });
        }

        function eliminarFila(index) {
            itemsVenta.splice(index, 1);
            renderizarTabla();
            actualizarTotales();
        }

        function actualizarTotales() {
            let bruto = 0;
            let final = 0;
            const tipoCobro = document.getElementById("tipoDescuento").value;

            // Elegimos la estrategia UNA SOLA VEZ (Patrón Strategy)
            const calcular = EstrategiasDescuento[tipoCobro];

            itemsVenta.forEach(item => {
                const sub = item.precio * item.cantidad;
                bruto += sub;

                // Aplicamos la estrategia elegida a cada producto
                final += calcular(sub, item.requiereReceta);
            });

            document.getElementById("txtSubtotalBruto").innerText = `$ ${bruto.toFixed(2)}`;
            document.getElementById("txtTotalFinal").innerText = `$ ${final.toFixed(2)}`;
            renderizarTabla();
        }

        
        document.getElementById("btnFinalizar").addEventListener("click", function() {
            if (itemsVenta.length === 0) return alert("Cargue al menos un producto.");

            const datos = {
                DniCliente: document.getElementById("dniCliente").value,
                TipoCobro: document.getElementById("tipoDescuento").value,
                Lineas: itemsVenta.map(i => ({
                    IdMedicamento: i.id,
                    Cantidad: i.cantidad,
                    Precio: i.precio
                }))
            };
         // --- CONFIRMAR VENTA---
            fetch('/Venta/ProcesarVenta', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(datos)
            })
                .then(async res => {
                    if (res.ok) {
                        const result = await res.json();
                        alert(`✅ ${result.msg}\nTotal cobrado: $${result.totalCobrado.toFixed(2)}`);
                        location.reload();
                    } else {
                        const errorText = await res.text();
                        alert("❌ Error: " + errorText);
                    }
                })
                .catch(err => {
                    console.error(err);
                    alert("❌ Error de red o del servidor.");
                });
        });

         // --- BÚSQUEDA DE MEDICAMENTOS ---
        const todasLasOpciones = Array.from(
            document.querySelectorAll("#opcionesOriginales option")
        );

        document.getElementById("buscarMedicamento").addEventListener("input", function () {
            const texto = this.value.trim().toLowerCase();
            const lista = document.getElementById("listaMedicamentos");

            lista.innerHTML = "";

            if (texto.length < 3) {
                lista.style.display = "none";
                return;
            }

            const coincidencias = todasLasOpciones.filter(op =>
                op.text.toLowerCase().includes(texto)
            );

            if (coincidencias.length === 0) {
                lista.innerHTML = `<div style="padding: 8px 12px; color: #999;">Sin resultados</div>`;
                lista.style.display = "block";
                return;
            }

            coincidencias.forEach(op => {
                const item = document.createElement("div");
                item.textContent = op.text;
                item.style.cssText = "padding: 8px 12px; cursor: pointer; border-bottom: 1px solid #f0f0f0;";

                item.addEventListener("mouseenter", () => item.style.background = "#e9f5ff");
                item.addEventListener("mouseleave", () => item.style.background = "white");

                item.addEventListener("click", () => {
                    document.getElementById("idMedicamento").value     = op.value;
                    document.getElementById("dataReceta").value        = op.getAttribute("data-receta");
                    document.getElementById("dataPrecio").value        = op.getAttribute("data-precio");
                    document.getElementById("dataStock").value         = op.getAttribute("data-stock");
                    document.getElementById("buscarMedicamento").value = op.text;
                    lista.style.display = "none";
                });

                lista.appendChild(item);
            });

            lista.style.display = "block";
        });

        document.addEventListener("click", function (e) {
            if (!e.target.closest("#buscarMedicamento") && !e.target.closest("#listaMedicamentos")) {
                document.getElementById("listaMedicamentos").style.display = "none";
            }
        });
    </script>
}