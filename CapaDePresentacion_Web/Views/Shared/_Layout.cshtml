@using Microsoft.AspNetCore.Http
@using CapaDeLogicaDeNegocio_BLL
@inject IHttpContextAccessor HttpContextAccessor
@{
    var idPerfil = HttpContextAccessor.HttpContext.Session.GetInt32("IdPerfil");
    var nombreUsuario = HttpContextAccessor.HttpContext.Session.GetString("NombreUsuario");
    var nombreRol = HttpContextAccessor.HttpContext.Session.GetString("NombreRol");

    // cada item del menu se decide preguntandole al composite si el perfil tiene el permiso
    var auth = AuthService.Instance;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Farmacia UPE</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CapaDePresentacion_Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">CapaDePresentacion_Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Inicio</a>
                    </li>

                    @if (auth.PerfilTienePermiso(idPerfil, "RegistrarVenta"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Venta" asp-action="Registrar">Ventas</a>
                        </li>
                    }

                    @if (auth.PerfilTienePermiso(idPerfil, "GestionarClientes"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Cliente" asp-action="Index">Clientes</a>
                        </li>
                    }

                    @if (auth.PerfilTienePermiso(idPerfil, "ControlStock"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Medicamento" asp-action="Index">Control de Stock</a>
                        </li>
                    }

                    @if (auth.PerfilTienePermiso(idPerfil, "RegistrarCompra"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Compra" asp-action="Registrar">Registrar Compra</a>
                        </li>
                    }

                    @if (auth.PerfilTienePermiso(idPerfil, "GestionarMedicamentos"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Medicamento" asp-action="Gestionar">Gestionar Medicamentos</a>
                        </li>
                    }

                    @if (auth.PerfilTienePermiso(idPerfil, "GestionarLaboratorios"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Laboratorio" asp-action="Index">Gestionar Laboratorios</a>
                        </li>
                    }

                    @if (auth.PerfilTienePermiso(idPerfil, "VerReportes"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Reporte" asp-action="Index">Reportes</a>
                        </li>
                    }

                    @if (auth.PerfilTienePermiso(idPerfil, "GestionarUsuarios"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Usuario" asp-action="Index">Usuarios</a>
                        </li>
                    }

                    @if (auth.PerfilTienePermiso(idPerfil, "ConfigurarPerfiles"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Perfil" asp-action="Index">Perfiles y Permisos</a>
                        </li>
                    }
                </ul>

                @if (idPerfil != null)
                {
                    <div class="navbar-text d-flex align-items-center">
                        <span class="badge bg-primary me-2">@nombreRol</span>
                        <a class="btn btn-sm btn-outline-danger" asp-controller="Account" asp-action="Logout">Salir</a>
                    </div>
                }
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CapaDePresentacion_Web
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
