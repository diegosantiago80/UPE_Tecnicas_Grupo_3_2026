@model IEnumerable<CapaDeEntidades.Perfil>
@{
    ViewData["Title"] = "Gestión de Perfiles";
}

<div class="container mt-4">
    <div class="card shadow-sm border-1" style="border-radius: 15px;">
        <div class="card-header bg-warning text-dark" style="padding: 12px 20px; border-top-left-radius: 15px; border-top-right-radius: 15px;">
            <h5 class="mb-0 fw-bold">Gestión de Perfiles</h5>
        </div>

        <div class="card-body p-4">
            @if (TempData["Exito"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2" style="border-radius: 10px;">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>@TempData["Exito"]</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2" style="border-radius: 10px;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@TempData["Error"]</span>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="d-flex justify-content-end mb-3">
                <a asp-action="Gestionar" class="btn bg-warning text-dark px-4 shadow-sm" style="font-weight: 500; border-radius: 20px;">
                    + Nuevo Perfil
                </a>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle" style="border-collapse: separate; border-spacing: 0;">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width: 150px;">ID Perfil</th>
                            <th class="text-center">Descripción</th>
                            <th class="text-center" style="width: 120px;">Modificar</th>
                            <th class="text-center" style="width: 120px;">Eliminar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var perfil in Model)
                            {
                                <tr>
                                    <td class="text-center text-muted">#@perfil.IdPerfil</td>
                                    <td class="text-center fw-semibold text-dark">@perfil.Descripcion</td>
                                    <td class="text-center">
                                        <a asp-action="Gestionar" asp-route-id="@perfil.IdPerfil" class="btn btn-sm btn-outline-secondary" style="border-radius: 10px;" title="Modificar Datos">
                                            ✏️ Editar
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        <form asp-action="Eliminar" method="post" class="d-inline form-eliminar">
                                            <input type="hidden" name="id" value="@perfil.IdPerfil" />
                                            <button type="button" class="btn btn-sm btn-outline-danger btn-confirmar-eliminar" data-nombre="@perfil.Descripcion">
                                                Eliminar
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">No se encontraron registros de perfiles.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".btn-confirmar-eliminar").forEach(btn => {
            btn.addEventListener("click", function () {
                const nombre = this.dataset.nombre;
                const form = this.closest("form");
                Swal.fire({
                    icon: "warning",
                    title: "¿Eliminar perfil?",
                    html: `¿Confirma la eliminación del perfil <strong>${nombre}</strong>?`,
                    showCancelButton: true,
                    confirmButtonText: "Sí, eliminar",
                    cancelButtonText: "Cancelar",
                    confirmButtonColor: "#dc3545",
                    cancelButtonColor: "#6c757d",
                    customClass: { popup: 'rounded-4' }
                }).then(result => {
                    if (result.isConfirmed) form.submit();
                });
            });
        });
    </script>
}