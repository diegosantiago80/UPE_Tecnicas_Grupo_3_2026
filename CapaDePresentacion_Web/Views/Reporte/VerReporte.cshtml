@using System
@using System.Collections.Generic
@using System.Linq
@using CapaDeEntidades;

@model IEnumerable<Reporte>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Reporte de Ventas";

    decimal totalVentas = 0;
    bool hayVentas = false;

    if (Model != null)
    {
        foreach (var v in Model)
        {
            totalVentas += v.Monto; // Sumamos el monto usando el bucle tradicional
            hayVentas = true;
        }
    }
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
            <h1 class="h4 mb-0 text-primary">Reporte de Ventas</h1>

            <form method="get" class="d-flex gap-2 mb-0">
                <input type="text" name="buscarVendedor" class="form-control w-auto" id="buscarVendedor" placeholder="Buscar vendedor..." title="Buscar por vendedor" />

                <select name="periodo" class="form-select w-auto" id="periodoSelect">
                    <option value="">-- Todos los períodos --</option>
                    <option value="diaria">Diaria</option>
                    <option value="semanal">Semanal</option>
                    <option value="mensual">Mensual</option>
                </select>

                <input type="date" name="fechaFiltro" class="form-control w-auto" id="fechaFiltro" title="Seleccionar fecha específica" />

                <button type="submit" class="btn btn-primary">Buscar</button>
            </form>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>ID Venta</th>
                            <th>Vendedor</th>
                            <th>Fecha de Venta</th>
                            <th>Medicamento / Artículo</th>
                            <th class="text-end">Monto</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (hayVentas)
                        {
                            foreach (var venta in Model)
                            {
                                <tr>
                                    <td>#@venta.IdVenta</td>
                                    <td>@venta.NombreVendedor</td>
                                    <td>@venta.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="fw-bold text-secondary">@venta.Medicamento</td>
                                    <td class="text-end fw-bold text-success">@venta.Monto.ToString("C")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    No se encontraron ventas de medicamentos para esta fecha/período.
                                </td>
                            </tr>
                        }
                    </tbody>

                    @if (hayVentas)
                    {
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="4" class="text-end fw-bold py-3">Total Facturado:</td>
                                <td class="text-end fw-bold fs-5 py-3 text-primary">
                                    @totalVentas.ToString("C")
                                </td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const urlParams = new URLSearchParams(window.location.search);

            const periodo = urlParams.get('periodo');
            if (periodo) {
                document.getElementById('periodoSelect').value = periodo;
            }

            const fechaFiltro = urlParams.get('fechaFiltro');
            if (fechaFiltro) {
                document.getElementById('fechaFiltro').value = fechaFiltro;
            }

            const buscarVendedor = urlParams.get('buscarVendedor');
            if (buscarVendedor) {
                document.getElementById('buscarVendedor').value = buscarVendedor;
            }
        });
    </script>
}