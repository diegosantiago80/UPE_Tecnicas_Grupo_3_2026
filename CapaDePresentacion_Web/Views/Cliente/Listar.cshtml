@model IEnumerable<CapaDeEntidades.Cliente>

@{
    ViewData["Title"] = "Listado de Clientes";
}

<div class="container mt-4">
    <div class="card shadow border-success">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h4><i class="bi bi-person-lines-fill"></i> Listado de Clientes Registrados</h4>
            <a asp-action="Gestionar" class="btn btn-light btn-sm fw-bold"><i class="bi bi-person-plus-fill"></i> Ir a gestión de clientes</a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mt-2">
                    <thead class="table-dark text-center">
                        <tr>
                            <th>Apellido</th>
                            <th>Nombre</th>
                            <th>DNI</th>
                            <th>Teléfono</th>
                            <th>Email</th>
                            <th>Obra Social</th>
                            <th>Empleado</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var cliente in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@cliente.Apellido</td>
                                    <td>@cliente.Nombre</td>
                                    <td class="text-center">@cliente.Dni</td>
                                    <td class="text-center">@cliente.Telefono</td>
                                    <td>@cliente.Email</td>
                                    <td class="text-center"><span class="badge bg-light text-dark border">@cliente.ObraSocial</span></td>
                                    <td class="text-center fw-bold">
                                        @if (cliente.EsEmpleado)
                                        {
                                            <span class="text-success"><i class="bi bi-check-circle-fill"></i> Sí</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (cliente.Activo)
                                        {
                                            <span class="badge bg-success">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactivo</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    No hay clientes registrados en el sistema.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
